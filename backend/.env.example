MONGODB_URI=mongodb://127.0.0.1:27017/woof
PORT=3001
# Optional override. By default the backend uses .venv, then python/python3.
# PYTHON_PATH=C:\absolute\path\to\python.exe

# Optional SARIMAX exogenous data providers.
# If these keys are missing or unavailable, Services forecasting gracefully
# degrades to cached/synthetic weather and hardcoded Philippine holidays.
OPENWEATHER_API_KEY=your_key_here
ABSTRACT_HOLIDAYS_KEY=your_key_here
LUCENA_LAT=13.9397
LUCENA_LNG=121.6145
